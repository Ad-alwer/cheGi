{
  "name": "python",
  "levels_info": {
    "1": "Essential",
    "2": "Recommended",
    "3": "Future/Frameworks",
    "4": "Pro/Advanced"
  },
  "levels": {
    "1": ["python", "pip", "virtualenv", "pipenv"],
    "2": ["black", "flake8", "mypy", "pytest", "ipython"],
    "3": ["django", "fastapi", "flask", "sqlalchemy", "celery"],
    "4": ["poetry", "tox", "ruff", "gunicorn", "alembic"]
  },
  "tools": {
    "python": { "check_cmd": "python --version", "install": { "apt": "sudo apt install python3 python3-pip", "brew": "brew install python", "winget": "winget install Python.Python.3.11" } },
    "pip": { "check_cmd": "pip --version", "install": { "apt": "sudo apt install python3-pip", "default": "python -m ensurepip --upgrade" } },
    "virtualenv": { "check_cmd": "virtualenv --version", "install": { "default": "pip install virtualenv" } },
    "pipenv": { "check_cmd": "pipenv --version", "install": { "default": "pip install pipenv" } },
    "black": { "check_cmd": "black --version", "install": { "default": "pip install black" } },
    "flake8": { "check_cmd": "flake8 --version", "install": { "default": "pip install flake8" } },
    "mypy": { "check_cmd": "mypy --version", "install": { "default": "pip install mypy" } },
    "pytest": { "check_cmd": "pytest --version", "install": { "default": "pip install pytest" } },
    "ipython": { "check_cmd": "ipython --version", "install": { "default": "pip install ipython" } },
    "django": { "check_cmd": "django-admin --version", "install": { "default": "pip install django" } },
    "fastapi": { "check_cmd": "python -c \"import fastapi\"", "install": { "default": "pip install fastapi uvicorn" } },
    "flask": { "check_cmd": "flask --version", "install": { "default": "pip install flask" } },
    "sqlalchemy": { "check_cmd": "python -c \"import sqlalchemy\"", "install": { "default": "pip install sqlalchemy" } },
    "celery": { "check_cmd": "celery --version", "install": { "default": "pip install celery" } },
    "poetry": { "check_cmd": "poetry --version", "install": { "default": "curl -sSL https://install.python-poetry.org | python3 -" } },
    "tox": { "check_cmd": "tox --version", "install": { "default": "pip install tox" } },
    "ruff": { "check_cmd": "ruff --version", "install": { "default": "pip install ruff" } },
    "gunicorn": { "check_cmd": "gunicorn --version", "install": { "default": "pip install gunicorn" } },
    "alembic": { "check_cmd": "alembic --version", "install": { "default": "pip install alembic" } }
  }
}
